# ─────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your real values.
# DO NOT commit .env.local — it contains secrets.
# ─────────────────────────────────────────────────────────────

# Stripe — required
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PRICE_ID=price_your_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Public site URL (used to build Stripe success/cancel URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — transactional email
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=CYT Course <hello@cytcourse.com>
RESEND_REPLY_TO=support@cytcourse.com
SUPPORT_EMAIL=support@cytcourse.com

# Optional logo (absolute URL) shown in the post-purchase email
# NEXT_PUBLIC_LOGO_URL=https://cytcourse.com/images/logo.png

# ─────────────────────────────────────────────────────────────
# In production (Vercel), set the same variables in
# Project → Settings → Environment Variables.
# Use sk_live_… and the production webhook signing secret.
# ─────────────────────────────────────────────────────────────
